<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loop2local — ยืนยันการบริจาค</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <nav class="navbar">
        <a href="map.html" class="nav-brand">
            <div class="nav-brand-icon" style="background:none;overflow:hidden">
                <img src="Logo.png" alt="Loop2local" style="width:100%;height:100%;object-fit:contain;border-radius:6px">
            </div>
            <span>Loop2local</span>
        </a>
        <div class="nav-links">
            <a href="map.html" class="nav-link" data-i="navMap">ค้นหาจุดบริจาค</a>
            <a href="donate.html" class="nav-link active" data-i="navDonate">ยืนยันการบริจาค</a>
            <a href="points.html" class="nav-link" data-i="navPoints">คะแนนสะสม</a>
            <a href="admin.html" class="nav-link admin-only" data-i="navAdmin">จัดการระบบ</a>
        </div>
        <button class="nav-hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
        <div class="nav-controls">
            <div class="nav-user-area"></div>
            <div class="lang-toggle"><button class="lang-btn active" data-lang="th">TH</button><button class="lang-btn" data-lang="en">EN</button></div>
            <button class="theme-toggle"><svg class="icon-moon" viewBox="0 0 20 20" fill="currentColor"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/></svg><svg class="icon-sun" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/></svg></button>
            <button class="btn-logout" data-i="logout">ออกจากระบบ</button>
        </div>
    </nav>
    <div class="nav-mobile-menu" id="mobileMenu">
        <a href="map.html" class="nav-link" data-i="navMap">ค้นหาจุดบริจาค</a>
        <a href="donate.html" class="nav-link active" data-i="navDonate">ยืนยันการบริจาค</a>
        <a href="points.html" class="nav-link" data-i="navPoints">คะแนนสะสม</a>
        <a href="admin.html" class="nav-link admin-only" data-i="navAdmin">จัดการระบบ</a>
        <a href="#" class="nav-link" style="color:var(--red)" onclick="document.querySelector('.btn-logout')?.click()" data-i="logout">ออกจากระบบ</a>
    </div>
    <div class="page">
        <div class="donate-wrap">
            <h1 class="page-title anim" data-i="donateTitle">ยืนยันการบริจาค</h1>
            <div class="stepper anim anim-d1">
                <div class="step-c now" id="step1">1</div>
                <div class="step-l" id="line1"></div>
                <div class="step-c" id="step2">2</div>
                <div class="step-l" id="line2"></div>
                <div class="step-c" id="step3">3</div>
            </div>
            <div class="step-labels anim anim-d1"><span>อัปโหลดรูป</span><span>AI ตรวจสอบ</span><span>ผลลัพธ์</span></div>
            <div id="phaseUpload" class="anim anim-d2">
                <div class="upload-box" id="uploadBox">
                    <input type="file" accept="image/*" class="upload-input" id="uploadInput">
                    <div class="u-icon"><svg viewBox="0 0 28 28" fill="none"><rect x="3" y="3" width="22" height="22" rx="3" stroke="currentColor" stroke-width="1.5"/><circle cx="10.5" cy="11.5" r="2.5" stroke="currentColor" stroke-width="1.5"/><path d="M3 19L9 13L13 17L18 11L25 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                    <h3>อัปโหลดรูปภาพ</h3>
                    <p>ถ่ายรูปขยะพลาสติก / กล่อง delivery ที่นำมาบริจาค</p>
                    <img class="preview" id="uploadPreview" alt="">
                </div>
                <button class="btn-primary" id="btnDonate" disabled>
                    <span>🤖 ส่งให้ AI ตรวจสอบ</span>
                </button>
                <p class="note" data-i="donateNote">AI จะวิเคราะห์รูปภาพทันที — ถ้าพบขยะจะอนุมัติอัตโนมัติ!</p>
            </div>
            <div id="phaseScanning" style="display:none">
                <div class="ai-scan-box">
                    <div class="scan-anim"><div class="scan-ring"></div><div class="scan-ring r2"></div><span class="scan-emoji">🤖</span></div>
                    <h3>AI กำลังวิเคราะห์...</h3>
                    <div class="scan-steps">
                        <div class="scan-step" id="ss1"><span class="sdot loading"></span> วิเคราะห์รูปภาพ</div>
                        <div class="scan-step" id="ss2"><span class="sdot"></span> ตรวจจับวัตถุ</div>
                        <div class="scan-step" id="ss3"><span class="sdot"></span> ประเมินผล</div>
                    </div>
                </div>
            </div>
            <div id="phaseApproved" style="display:none">
                <div class="result-box ok">
                    <div class="result-icon">✅</div>
                    <h3>AI อนุมัติอัตโนมัติ!</h3>
                    <p id="aiDesc">ตรวจพบขยะพลาสติก/delivery ในรูปภาพ</p>
                    <div class="conf-row"><span>ความมั่นใจ:</span><div class="conf-bar"><div class="conf-fill" id="confFill"></div></div><span id="confPct">0%</span></div>
                    <div class="points-earned show"><div class="big">+25</div><div style="font-size:.9rem;color:var(--text-secondary);margin-top:6px">คุณได้รับ <strong style="color:var(--g-600)">25</strong> คะแนน!</div></div>
                    <a href="points.html" class="btn-primary" style="display:inline-flex;width:auto;padding:12px 28px;text-decoration:none;margin-top:14px">ดูคะแนนของฉัน →</a>
                </div>
            </div>
            <div id="phaseRejected" style="display:none">
                <div class="result-box pending">
                    <div class="result-icon">❌</div>
                    <h3>AI ไม่พบขยะในรูป</h3>
                    <p>กรุณาถ่ายรูปขยะพลาสติก / กล่อง delivery ให้ชัดเจนแล้วลองใหม่</p>
                    <div class="pending-badge">🔄 ระบบจะให้ลองใหม่อัตโนมัติ...</div>
                </div>
            </div>
        </div>
    </div>
    <script src="script.js"></script>
</body>
</html>
